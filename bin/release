#!/usr/bin/env bash
# Whisper Pilot release script.
#
# Builds a DMG, optionally signs + notarizes it, publishes a GitHub Release with the
# DMG attached, and bumps the Homebrew tap so `brew upgrade --cask whisper-pilot`
# picks up the new version. The same script is invoked by
# `.github/workflows/release.yml` — CI and local releases produce identical artifacts.
#
# Usage:
#   ./bin/release --version 0.2.0              # full release (build + publish + tap)
#   ./bin/release 0.2.0                        # positional form, same effect
#   ./bin/release --version 0.2.0 --build-only # just produce a DMG, no uploads
#   ./bin/release --version 0.2.0 --skip-tap   # publish Release but don't touch tap
#   ./bin/release --help
#
# Environment variables (all optional):
#   WP_DEVELOPER_ID              Codesign identity ("Developer ID Application: …")
#   WP_APPLE_ID + WP_APPLE_APP_PASSWORD + WP_TEAM_ID    Notarization credentials
#   TAP_REPO_TOKEN               Fine-grained PAT with Contents:Write on the tap repo.
#                                Used by CI to push the cask update. Locally, the script
#                                falls back to your `gh auth setup-git` credentials.
#   GH_TOKEN / GITHUB_TOKEN      Used by `gh release create`. CI sets these automatically;
#                                locally, `gh auth login` once is enough.
set -euo pipefail
cd "$(dirname "$0")/.."

# Fail loudly. With just `set -e` a build failure mid-script exits non-zero, but
# in a noisy log (xcodebuild can dump 50+ errors) the actual "release aborted"
# signal is easy to miss. This trap prints a banner pointing at the last command
# attempted so the reader knows *exactly* where the script gave up, and confirms
# no Release / tap update happened. Stays in effect for the entire script.
__on_error() {
  local exit_code=$?
  local last_cmd=${BASH_COMMAND}
  printf '\n\033[1;31m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m\n' >&2
  printf '\033[1;31m✗ RELEASE FAILED\033[0m (exit %s)\n' "$exit_code" >&2
  printf '   Last command: %s\n' "$last_cmd" >&2
  printf '   Nothing was published. Fix the error above and re-run.\n' >&2
  printf '\033[1;31m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m\n' >&2
  exit "$exit_code"
}
trap __on_error ERR

# --- Help ------------------------------------------------------------------
usage() {
  cat <<'EOF'
Whisper Pilot release script.

Usage:
  ./bin/release [--version X.Y.Z] [flags]

Flags:
  -v, --version VERSION   Version to release (e.g. 0.2.0). Falls back to
                          CFBundleShortVersionString in Project.yml if omitted.
      --build-only        Produce the DMG locally only. Skip GitHub Release
                          and Homebrew tap update.
      --skip-publish      Build (and update tap, if enabled). Skip GH Release.
      --skip-tap          Build + create GH Release. Skip the tap update.
  -h, --help              Show this help.

Examples:
  ./bin/release --version 0.2.0           # full release
  ./bin/release --version 0.2.0 --build-only
  ./bin/release 0.0.1 --build-only        # positional version, build only
EOF
}

# --- Arg parsing -----------------------------------------------------------
VERSION=""
BUILD_ONLY=0
SKIP_PUBLISH=0
SKIP_TAP=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -v|--version)
      if [[ $# -lt 2 ]]; then echo "Error: --version requires a value" >&2; exit 1; fi
      VERSION="$2"; shift 2 ;;
    --build-only)    BUILD_ONLY=1; shift ;;
    --skip-publish)  SKIP_PUBLISH=1; shift ;;
    --skip-tap)      SKIP_TAP=1; shift ;;
    -h|--help)       usage; exit 0 ;;
    --)              shift; break ;;
    -*)              echo "Unknown flag: $1" >&2; usage >&2; exit 1 ;;
    *)
      if [[ -z "$VERSION" ]]; then VERSION="$1"
      else echo "Error: unexpected argument '$1'" >&2; exit 1
      fi
      shift ;;
  esac
done

# --- Default version: bump patch off the latest published release ---------
# When the caller omits --version, we auto-pick "last released version + 0.0.1"
# so back-to-back releases don't accidentally re-publish the same tag. Source
# of truth, in order: GitHub Releases (canonical), local git tags (offline
# fallback), then Project.yml as a last resort. The Project.yml fallback is
# only hit when both gh and git tags are unavailable (e.g. fresh checkout
# with no remote auth) — it will keep the script working but you'll need to
# bump Project.yml manually to avoid clobbering.
bump_patch() {
  local v="${1#v}"
  if [[ ! "$v" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]; then return 1; fi
  echo "${BASH_REMATCH[1]}.${BASH_REMATCH[2]}.$(( BASH_REMATCH[3] + 1 ))"
}

latest_released_version() {
  local tag=""
  if command -v gh >/dev/null && gh auth status >/dev/null 2>&1; then
    tag="$(gh release list --limit 50 --json tagName -q '.[].tagName' 2>/dev/null \
      | grep -E '^v?[0-9]+\.[0-9]+\.[0-9]+$' \
      | sed 's/^v//' \
      | sort -V \
      | tail -1)"
  fi
  if [[ -z "$tag" ]]; then
    tag="$(git tag --list 'v*' --sort=-v:refname 2>/dev/null \
      | grep -E '^v?[0-9]+\.[0-9]+\.[0-9]+$' \
      | sed 's/^v//' \
      | head -1)"
  fi
  [[ -n "$tag" ]] && echo "$tag"
}

if [[ -z "$VERSION" ]]; then
  LAST_RELEASED="$(latest_released_version || true)"
  if [[ -n "$LAST_RELEASED" ]] && NEXT="$(bump_patch "$LAST_RELEASED")"; then
    VERSION="$NEXT"
    echo "Auto-selected version $VERSION (last released: $LAST_RELEASED)"
  else
    VERSION="$(awk '/CFBundleShortVersionString/ { gsub(/"/, "", $2); print $2; exit }' Project.yml || true)"
    [[ -n "$VERSION" ]] && echo "No prior release found; falling back to Project.yml version $VERSION"
  fi
fi
VERSION="${VERSION#v}"  # strip leading v if present

if [[ -z "$VERSION" ]]; then
  echo "Error: no version supplied, no prior release found, and Project.yml has no CFBundleShortVersionString." >&2
  usage >&2
  exit 1
fi

if [[ $BUILD_ONLY -eq 1 ]]; then
  SKIP_PUBLISH=1
  SKIP_TAP=1
fi

# --- Constants -------------------------------------------------------------
SCHEME="WhisperPilot"
BUILD_DIR="build"
ARCHIVE_PATH="${BUILD_DIR}/WhisperPilot.xcarchive"
EXPORT_DIR="${BUILD_DIR}/export"
APP_PATH="${EXPORT_DIR}/WhisperPilot.app"
DMG_PATH="${BUILD_DIR}/WhisperPilot-${VERSION}.dmg"
TAP_REPO="vertocode/homebrew-whisper-pilot"

# --- Logging helpers -------------------------------------------------------
if [[ -t 1 ]]; then
  C_STEP=$'\033[1;34m'; C_OK=$'\033[1;32m'; C_WARN=$'\033[1;33m'; C_RESET=$'\033[0m'
else
  C_STEP=''; C_OK=''; C_WARN=''; C_RESET=''
fi
step()      { printf "\n%s▸%s %s\n" "$C_STEP" "$C_RESET" "$*"; }
done_step() { printf "%s✓%s %s\n" "$C_OK" "$C_RESET" "$*"; }
warn()      { printf "%s!%s %s\n" "$C_WARN" "$C_RESET" "$*" >&2; }

# --- Prereq checks ---------------------------------------------------------
command -v xcodegen   >/dev/null || { echo "Missing xcodegen — run: brew install xcodegen"   >&2; exit 1; }
command -v xcodebuild >/dev/null || { echo "Missing xcodebuild — install Xcode."             >&2; exit 1; }
command -v create-dmg >/dev/null || { echo "Missing create-dmg — run: brew install create-dmg" >&2; exit 1; }

if [[ $SKIP_PUBLISH -eq 0 ]] || [[ $SKIP_TAP -eq 0 ]]; then
  command -v gh >/dev/null || { echo "Missing gh CLI — run: brew install gh && gh auth login." >&2; exit 1; }
fi

if [[ $SKIP_PUBLISH -eq 0 ]]; then
  if ! gh auth status >/dev/null 2>&1 && [[ -z "${GH_TOKEN:-}${GITHUB_TOKEN:-}" ]]; then
    echo "Error: gh CLI is not authenticated. Run 'gh auth login' (or set GH_TOKEN)." >&2
    exit 1
  fi
fi

# --- Build -----------------------------------------------------------------
step "Regenerating Xcode project"
./bin/regenerate

step "Cleaning previous build artifacts"
rm -rf "${BUILD_DIR}"
mkdir -p "${EXPORT_DIR}"

if [[ -n "${WP_DEVELOPER_ID:-}" ]]; then
  SIGN_METHOD="developer-id"
  SIGN_IDENTITY="${WP_DEVELOPER_ID}"
  step "Code-sign identity: ${SIGN_IDENTITY}"
else
  SIGN_METHOD="none"
  SIGN_IDENTITY="-"
  warn "No WP_DEVELOPER_ID set — building unsigned. Users will see a Gatekeeper warning."
fi

run_xcodebuild() {
  if command -v xcbeautify >/dev/null; then
    xcodebuild "$@" 2>&1 | xcbeautify --quieter
    return ${PIPESTATUS[0]}
  else
    xcodebuild "$@"
  fi
}

step "Archiving (Release, version ${VERSION})"
run_xcodebuild \
    -project WhisperPilot.xcodeproj \
    -scheme "${SCHEME}" \
    -configuration Release \
    -archivePath "${ARCHIVE_PATH}" \
    -destination "platform=macOS" \
    MARKETING_VERSION="${VERSION}" \
    CODE_SIGN_IDENTITY="${SIGN_IDENTITY}" \
    archive

[[ -d "${ARCHIVE_PATH}" ]] || { echo "Archive failed." >&2; exit 1; }

# Extract the .app from the archive. For signed builds we go through
# `xcodebuild -exportArchive` with a method=developer-id plist; for unsigned
# builds we just copy the .app out of the archive directly — Xcode rejects
# any "method=none" plist value, and there's nothing for the exporter to do
# when there's no Developer ID anyway.
if [[ "${SIGN_METHOD}" == "developer-id" ]]; then
  step "Exporting signed .app"
  EXPORT_PLIST="${BUILD_DIR}/ExportOptions.plist"
  cat > "${EXPORT_PLIST}" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>method</key><string>developer-id</string>
    <key>signingStyle</key><string>manual</string>
    <key>destination</key><string>export</string>
</dict>
</plist>
EOF
  run_xcodebuild \
      -exportArchive \
      -archivePath "${ARCHIVE_PATH}" \
      -exportPath "${EXPORT_DIR}" \
      -exportOptionsPlist "${EXPORT_PLIST}"
else
  step "Copying unsigned .app out of archive"
  ARCHIVE_APP="${ARCHIVE_PATH}/Products/Applications/WhisperPilot.app"
  [[ -d "${ARCHIVE_APP}" ]] || { echo "No .app found inside archive at ${ARCHIVE_APP}" >&2; exit 1; }
  cp -R "${ARCHIVE_APP}" "${APP_PATH}"
fi

[[ -d "${APP_PATH}" ]] || { echo "Export failed — no .app at ${APP_PATH}" >&2; exit 1; }

# --- Optional: notarize the .app -------------------------------------------
if [[ "${SIGN_METHOD}" == "developer-id" \
   && -n "${WP_APPLE_ID:-}" \
   && -n "${WP_APPLE_APP_PASSWORD:-}" \
   && -n "${WP_TEAM_ID:-}" ]]; then
  step "Zipping for notarization"
  NOTARIZE_ZIP="${BUILD_DIR}/WhisperPilot-notarize.zip"
  ditto -c -k --keepParent "${APP_PATH}" "${NOTARIZE_ZIP}"

  step "Submitting to Apple for notarization (1–10 min)"
  xcrun notarytool submit "${NOTARIZE_ZIP}" \
      --apple-id "${WP_APPLE_ID}" \
      --password "${WP_APPLE_APP_PASSWORD}" \
      --team-id "${WP_TEAM_ID}" \
      --wait

  step "Stapling notarization ticket to .app"
  xcrun stapler staple "${APP_PATH}"
  rm -f "${NOTARIZE_ZIP}"
else
  warn "Skipping notarization (set WP_APPLE_ID, WP_APPLE_APP_PASSWORD, WP_TEAM_ID to enable)"
fi

# --- Build the DMG ---------------------------------------------------------
step "Building DMG"
STAGE_DIR="${BUILD_DIR}/dmg-stage"
rm -rf "${STAGE_DIR}"
mkdir -p "${STAGE_DIR}"
cp -R "${APP_PATH}" "${STAGE_DIR}/"

create-dmg \
    --volname "Whisper Pilot ${VERSION}" \
    --window-pos 200 120 \
    --window-size 600 380 \
    --icon-size 110 \
    --icon "WhisperPilot.app" 170 200 \
    --hide-extension "WhisperPilot.app" \
    --app-drop-link 430 200 \
    --no-internet-enable \
    "${DMG_PATH}" \
    "${STAGE_DIR}/"

if [[ "${SIGN_METHOD}" == "developer-id" ]]; then
  step "Signing the DMG"
  codesign --force --sign "${SIGN_IDENTITY}" "${DMG_PATH}"

  if [[ -n "${WP_APPLE_ID:-}" && -n "${WP_APPLE_APP_PASSWORD:-}" && -n "${WP_TEAM_ID:-}" ]]; then
    step "Notarizing the DMG"
    xcrun notarytool submit "${DMG_PATH}" \
        --apple-id "${WP_APPLE_ID}" \
        --password "${WP_APPLE_APP_PASSWORD}" \
        --team-id "${WP_TEAM_ID}" \
        --wait
    xcrun stapler staple "${DMG_PATH}"
  fi
fi

SHA256="$(shasum -a 256 "${DMG_PATH}" | awk '{print $1}')"
echo "${SHA256}  $(basename "${DMG_PATH}")" > "${DMG_PATH}.sha256"

done_step "DMG ready: ${DMG_PATH}"
echo "  SHA-256:  ${SHA256}"

if [[ $BUILD_ONLY -eq 1 ]]; then
  echo
  done_step "Build-only mode: skipping publish + tap update."
  exit 0
fi

# --- Publish to GitHub Releases --------------------------------------------
if [[ $SKIP_PUBLISH -eq 0 ]]; then
  step "Publishing GitHub Release v${VERSION}"
  NOTES="**SHA-256:** \`${SHA256}\`

Install via Homebrew (after the tap is updated):
\`\`\`
brew install --cask vertocode/whisper-pilot/whisper-pilot
\`\`\`
or download the .dmg below."

  if gh release view "v${VERSION}" >/dev/null 2>&1; then
    gh release upload "v${VERSION}" "${DMG_PATH}" --clobber
    done_step "Updated existing release v${VERSION}"
  else
    gh release create "v${VERSION}" "${DMG_PATH}" \
        --title "Whisper Pilot ${VERSION}" \
        --notes "${NOTES}"
    done_step "Created release v${VERSION}"
  fi
fi

# --- Update Homebrew tap ---------------------------------------------------
if [[ $SKIP_TAP -eq 0 ]]; then
  step "Updating Homebrew tap (${TAP_REPO})"
  TAP_DIR="${BUILD_DIR}/tap"
  rm -rf "${TAP_DIR}"

  # When run from CI, TAP_REPO_TOKEN is the explicit way to authenticate. When run
  # locally, the user's `gh auth setup-git` credential helper handles auth invisibly.
  if [[ -n "${TAP_REPO_TOKEN:-}" ]]; then
    CLONE_URL="https://x-access-token:${TAP_REPO_TOKEN}@github.com/${TAP_REPO}.git"
  else
    CLONE_URL="https://github.com/${TAP_REPO}.git"
  fi

  if ! git clone --quiet "${CLONE_URL}" "${TAP_DIR}"; then
    warn "Couldn't clone the tap repo. Make sure either:"
    warn "  - You're logged in via 'gh auth login' (and ran 'gh auth setup-git'), OR"
    warn "  - You have TAP_REPO_TOKEN set in your environment."
    warn "Skipping tap update — Release was created, you can update the cask manually."
    exit 0
  fi

  (
    cd "${TAP_DIR}"
    sed -i.bak "s/^  version .*/  version \"${VERSION}\"/" Casks/whisper-pilot.rb
    sed -i.bak "s/^  sha256 .*/  sha256 \"${SHA256}\"/"  Casks/whisper-pilot.rb
    rm -f Casks/whisper-pilot.rb.bak

    if git diff --quiet; then
      done_step "Tap already at v${VERSION} — nothing to commit."
    else
      git -c user.email="release@whisperpilot.app" \
          -c user.name="Whisper Pilot Release" \
          add Casks/whisper-pilot.rb
      git -c user.email="release@whisperpilot.app" \
          -c user.name="Whisper Pilot Release" \
          commit --quiet -m "chore: bump to v${VERSION}"
      git push --quiet
      done_step "Tap updated. Users running 'brew upgrade --cask whisper-pilot' will get v${VERSION}."
    fi
  )
fi

echo
done_step "Release v${VERSION} complete."
